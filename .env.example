# ─── Solana Jito Flash Searcher — Environment Configuration ───
# Copy this file to .env and fill in your values.

# ─── Bot Identity ────────────────────────────────────────────
# A friendly name for this bot instance (used in logs)
BOT_NAME=local

# ─── Keypairs (REQUIRED) ────────────────────────────────────
# Path to your Solana wallet keypair JSON (needs SOL for gas)
PAYER_KEYPAIR_PATH=./payer.json

# Path to your Jito Block Engine authentication keypair JSON
# Get one at: https://jito-labs.gitbook.io/mev/searcher-resources/getting-started
AUTH_KEYPAIR_PATH=./auth.json

# ─── RPC (REQUIRED) ─────────────────────────────────────────
# Jito-compatible RPC URL (must support simulateBundle)
RPC_URL=https://frankfurt.mainnet.rpc.jito.wtf

# Rate limit for RPC requests (0 = unlimited)
RPC_REQUESTS_PER_SECOND=200

# Maximum number of requests batched into a single JSON-RPC call
RPC_MAX_BATCH_SIZE=15

# ─── Jito Block Engine (REQUIRED) ───────────────────────────
# Comma-separated Block Engine URLs (bot subscribes to all, sends to first)
BLOCK_ENGINE_URLS=frankfurt.mainnet.block-engine.jito.wtf,amsterdam.mainnet.block-engine.jito.wtf

# ─── Geyser (REQUIRED) ──────────────────────────────────────
# Geyser gRPC endpoint for real-time account updates
GEYSER_URL=frankfurt.mainnet.rpc.jito.wtf

# Geyser access token
GEYSER_ACCESS_TOKEN=00000000-0000-0000-0000-000000000000

# ─── Tip Configuration ──────────────────────────────────────
# Percentage of net profit sent as tip to Jito validators (default: 25)
TIP_PERCENT=25

# Minimum tip in lamports — floor applied when dynamic tip is too small
MIN_TIP_LAMPORTS=10000

# ─── Arb Calculation ────────────────────────────────────────
# Number of step sizes to try when calculating optimal arb size
ARB_CALCULATION_NUM_STEPS=3

# Maximum time (ms) to spend on arb route calculation per trade
MAX_ARB_CALCULATION_TIME_MS=15

# ─── Worker Threads ─────────────────────────────────────────
# Number of worker threads for parallel AMM calculations
NUM_WORKER_THREADS=4

# ─── Simulation Mode ────────────────────────────────────────
# Set to true to run the full pipeline WITHOUT broadcasting bundles.
# Useful for testing and dry-running. (default: false)
SIMULATION_MODE=false

# ─── Logging ────────────────────────────────────────────────
# Log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# ─── Node Environment ───────────────────────────────────────
NODE_ENV=production
